{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FastMM",
  "version": "0.1.0",
  "identifier": "jp.co.wizard-lab.fastmm",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "FastMM",
        "width": 1280,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["Japanese", "English"],
        "startMenuFolder": "FastMM"
      }
    }
  }
}
